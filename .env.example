# GitHub (required — https://github.com/settings/tokens, public_repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx

# Twitter API v2 — OAuth 1.0a (required for posting)
# Get at https://developer.twitter.com/en/portal/projects-and-apps
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Telegram bot for error alerts (optional — reuse existing bot)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard public URL (used in tweet links)
DASHBOARD_URL=https://harnesspulse.mrb.sh

# Data directory (default: ./data)
DATA_DIR=./data
